# The location where iCloud photos are downloaded
ICLOUD_PHOTOS_DIR=/path/to/icloud-photos

# The location where iCloud auth credentials are stored
ICLOUD_AUTH_DIR=/path/to/project/configs/auth

# iCloud account username/email
ICLOUD_USERNAME=your-email@example.com

# Timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Etc/UTC
